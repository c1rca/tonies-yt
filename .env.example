# Tonies advanced overrides
TONIES_LOGIN_URL=https://login.tonies.com
TONIES_APP_URL=https://my.tonies.com

# Optional selector overrides (if Tonies UI changes)
TONIES_LOGIN_EMAIL_SELECTOR=input[type='email']
TONIES_LOGIN_PASSWORD_SELECTOR=input[type='password']
TONIES_LOGIN_SUBMIT_SELECTOR=button[type='submit']
TONIES_SEARCH_CHARACTER_SELECTOR=input[placeholder*='Search']
TONIES_UPLOAD_BUTTON_SELECTOR=button:has-text('Upload')
TONIES_FILE_INPUT_SELECTOR=input[type='file']

# App
APP_PORT=8080
DATA_DIR=/app/data
TONIES_STORAGE_STATE_FILE=/app/data/tonies-storage-state.json

# Logging
LOG_LEVEL=DEBUG
LOG_FILE=/app/data/logs/toni-auto.log
